{
  "remoteControlAtStartup": true,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "WebFetch(*)",
      "WebSearch",
      "Skill(*)",
      "mcp__apollo__get_calibration_stats",
      "mcp__apollo__configure_target",
      "mcp__apollo__trigger_closure_ceremony"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(rm -rf /mnt/c/Apollo)",
      "Bash(docker system prune*)"
    ],
    "defaultMode": "default"
  }
}
