 const m = obj.message || {};\n    const role = m.role;\n    if (!['user','assistant'].includes(role)) continue;\n    const content = Array.isArray(m.content) ? m.content : [];\n    const text = content.filter(p => p.type === 'text').map(p => p.text || '').join(' ').replace(/\\s+/g,' ').trim();\n    if (!text) continue;\n    msgs.push({ts: obj.timestamp, role, text: text.length > 380 ? text.slice(0,380) + '...' : text});\n  }\n  for (const msg of msgs.slice(-4)) {\n    console.log(`${msg.ts} | ${msg.role}: ${msg.text}`);\n  }\n  console.log();\n}\nNODE","workdir":"/home/node/.openclaw/workspace","yieldMs":10000,"timeout":25},"partialJson":"{\"command\":\"node - <<'NODE'\\nconst fs = require('fs');\\nconst path = require('path');\\nconst dir = 'Intel/agents/main/sessions';\\nconst files = fs.readdirSync(dir)\\n  .filter(f => f.endsWith('.jsonl') || f.includes('.jsonl.reset.'))\\n  .sort();\\nfor (const file of files) {\\n  console.log(`===== ${file} =====`);\\n  const raw = fs.readFileSync(path.join(dir, file), 'utf8').split('\\\\n');\\n  const msgs = [];\\n  for (const line of raw) {\\n    if (!line.trim()) continue;\\n    let obj;\\n    try { obj = JSON.parse(line); } catch { continue; }\\n    if (obj.type !== 'message') continue;\\n    const m = obj.message || {};\\n    const role = m.role;\\n    if (!['user','assistant'].includes(role)) continue;\\n    const content = Array.isArray(m.content) ? m.content : [];\\n    const text = content.filter(p => p.type === 'text').map(p => p.text || '').join(' ').replace(/\\\\s+/g,' ').trim();\\n    if (!text) continue;\\n    msgs.push({ts: obj.timestamp, role, text: text.length > 380 ? text.slice(0,380) + '...' : text});\\n  }\\n  for (const msg of msgs.slice(-4)) {\\n    console.log(`${msg.ts} | ${msg.role}: ${msg.text}`);\\n  }\\n  console.log();\\n}\\nNODE\",\"workdir\":\"/home/node/.openclaw/workspace\",\"yieldMs\":10000,\"timeout\":25}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":