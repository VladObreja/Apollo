\"\" http://localhost:3000\n    42\t\n    43\techo ==========================================\n    44\techo STATION ONLINE - CORE SERVICES HEALTHY\n    45\techo Compose command: %COMPOSE_CMD%\n    46\techo OpenClaw:  http://localhost:18789\n    47\techo Open WebUI: http://localhost:3000\n    48\techo ==========================================\n    49\texit /b 0\n    50\t\n    51\t:detect_docker\n    52\twhere docker >nul 2>&1\n    53\tif errorlevel 1 (\n    54\t  echo Docker CLI not found in PATH.\n    55\t  exit /b 1\n    56\t)\n    57\texit /b 0\n    58\t\n    59\t:detect_compose\n    60\tdocker compose version >nul 2>&1\n    61\tif not errorlevel 1 (\n    62\t  set \"COMPOSE_CMD=docker compose\"\n    63\t  exit /b 0\n    64\t)\n    65\twhere docker-compose >nul 2>&1\n    66\tif errorlevel 1 (\n    67\t  echo Neither \"docker compose\" nor \"docker-compose\" is available.\n    68\t  exit /b 1\n    69\t)\n    70\tset \"COMPOSE_CMD=docker-compose\"\n    71\texit /b 0\n    72\t\n    73\t:check_docker_daemon\n    74\techo Checking Docker daemon...\n    75\tdocker info >nul 2>&1\n    76\tif errorlevel 1 (\n    77\t  echo Docker daemon is not reachable. Start Docker Desktop first.\n    78\t  exit /b 1\n    79\t)\n    80\texit /b 0\n    81\t\n    82\t:wait_healthy\n    83\tset \"CONTAINER=%~1\"\n    84\tset /a TIMEOUT=%~2\n    85\tset /a ELAPSED=0\n    86\t:wait_healthy_loop\n    87\tset \"STATUS=\"\n    88\tfor /f \"delims=\" %%S in ('docker inspect -f \"{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}\" \"%CONTAINER%\" 2^>nul') do set \"STATUS=%%S\"\n    89\tif /I \"!STATUS!\"==\"healthy\" (\n    90\t  echo     %CONTAINER% is healthy.\n    91\t  exit /b 0\n    92\t)\n    93\tif /I \"!STATUS!\"==\"unhealthy\" (\n    94\t  echo     %CONTAINER% reported unhealthy.\n    95\t  exit /b 1\n    96\t)\n    97\tif /I \"!STATUS!\"==\"exited\" (\n    98\t  echo     %CONTAINER% exited unexpectedly.\n    99\t  exit /b 1\n   100\t)\n   101\tif !ELAPSED! GE