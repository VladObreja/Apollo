'\\\\bapollo\\\\b', r'openclaw', r'lightrag', r'vault', r'ollama', r'open webui', r'crawl4ai', r'mcp', r'project apollo', r'knowledge engine'],\\n    'aurelius': [r'\\\\baurelius\\\\b', r'hfmp', r'post-finasteride', r'post-androgen', r'pfs', r'pssd', r'proviron', r'mesterolone', r'photobiomodulation', r'pelvic floor', r'bh4', r'pterin', r'erectile', r'neuroendocrine', r'metabolic'],\\n}\\n\\nentries = {'apollo': [], 'aurelius': []}\\nfor chunk in chunks:\\n    body = '## Entry ' + chunk\\n    low = body.lower()\\n    for proj, pats in project_rules.items():\\n        if any(re.search(p, low) for p in pats):\\n            m_ts = re.search(r'\\\\*\\\\*Timestamp:\\\\*\\\\*\\\\s*(.+)', body)\\n            ts = m_ts.group(1).strip() if m_ts else 'Unknown'\\n            m_prompt = re.search(r'### Prompt\\\\n\\\\n(.*?)\\\\n\\\\n### Response', body, re.S)\\n            prompt = m_prompt.group(1).strip() if m_prompt else ''\\n            prompt = prompt.replace('\\\\n', ' ')[:240]\\n            entries[proj].append({'timestamp': ts, 'prompt': prompt, 'body': body.strip()})\\n            break\\n\\ndef build_timeline(project):\\n    pdir = base / project\\n    sources = sorted((pdir / 'sources').glob('*'))\\n    out = []\\n    out.append(f'# {project.title()} Timeline')\\n    out.append('')\\n    out.append('## Canonical source files')\\n    out.append('')\\n    for s in sources:\\n        out.append(f'- `{s.name}`')\\n    out.append('')\\n    out.append('## Conversation-derived timeline')\\n    out.append('')\\n    if not entries[project]:\\n        out.append('_No matching conversation entries found yet._')\\n    else:\\n        for i, e in enumerate(entries[project], start=1):\\n            out.append(f'### Timeline Entry {i}')\\n            out.append('')\\n            out.append(f'**Timestamp:** {e[\\\"timestamp\\\"]}')\\n            out.append('')\\n            out.append(f'**Prompt summary:** {e[\\\"prompt\\\"]}')\\n            out.append('')\\n            out.append(e