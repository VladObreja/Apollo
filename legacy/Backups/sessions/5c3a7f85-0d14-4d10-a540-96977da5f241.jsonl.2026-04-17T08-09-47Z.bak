{"type":"message","id":"a32ea20f","parentId":"2c973b73","timestamp":"2026-04-17T06:51:17.730Z","message":{"role":"toolResult","toolCallId":"call_34Qdt9ldbZVd1Sf1YAfnDyzW|fc_02ad8e5e7b4217730169e1d86589d88191b9ac99b785d509f4","toolName":"exec","content":[{"type":"text","text":"Backed up: docker-compose.yaml -> legacy/Backups/docker-compose.yaml.v2.2026-04-17T06-51-17Z.bak\nBacked up: apollo_up.bat -> legacy/Backups/apollo_up.bat.v2.2026-04-17T06-51-17Z.bak\nBacked up: apollo_down.bat -> legacy/Backups/apollo_down.bat.v2.2026-04-17T06-51-17Z.bak\nBacked up: .env -> legacy/Backups/.env.v2.2026-04-17T06-51-17Z.bak\nBacked up: AGENTS.md -> legacy/Backups/AGENTS.md.v2.2026-04-17T06-51-17Z.bak\nAGENTS.md.v1.2026-04-17T06-20-17Z.bak\nAGENTS.md.v2.2026-04-17T06-51-17Z.bak\napollo_down.bat.v1.2026-04-17T06-20-17Z.bak\napollo_down.bat.v2.2026-04-17T06-51-17Z.bak\napollo_up.bat.v1.2026-04-17T06-20-17Z.bak\napollo_up.bat.v2.2026-04-17T06-51-17Z.bak\ndocker-compose.yaml.v1.2026-04-17T06-20-17Z.bak\ndocker-compose.yaml.v2.2026-04-17T06-51-17Z.bak"}],"details":{"status":"completed","exitCode":0,"durationMs":97,"aggregated":"Backed up: docker-compose.yaml -> legacy/Backups/docker-compose.yaml.v2.2026-04-17T06-51-17Z.bak\nBacked up: apollo_up.bat -> legacy/Backups/apollo_up.bat.v2.2026-04-17T06-51-17Z.bak\nBacked up: apollo_down.bat -> legacy/Backups/apollo_down.bat.v2.2026-04-17T06-51-17Z.bak\nBacked up: .env -> legacy/Backups/.env.v2.2026-04-17T06-51-17Z.bak\nBacked up: AGENTS.md -> legacy/Backups/AGENTS.md.v2.2026-04-17T06-51-17Z.bak\nAGENTS.md.v1.2026-04-17T06-20-17Z.bak\nAGENTS.md.v2.2026-04-17T06-51-17Z.bak\napollo_down.bat.v1.2026-04-17T06-20-17Z.bak\napollo_down.bat.v2.2026-04-17T06-51-17Z.bak\napollo_up.bat.v1.2026-04-17T06-20-17Z.bak\napollo_up.bat.v2.2026-04-17T06-51-17Z.bak\ndocker-compose.yaml.v1.2026-04-17T06-20-17Z.bak\ndocker-compose.yaml.v2.2026-04-17T06-51-17Z.bak","cwd":"/home/node/.openclaw/workspace"},"isError":false,"timestamp":1776408677722}}
{"type":"message","id":"1847766f","parentId":"a32ea20f","timestamp":"2026-04-17T06:51:17.741Z","message":{"role":"toolResult","toolCallId":"call_ocnlmJzveaHIqbIxb5QZPYcd|fc_02ad8e5e7b4217730169e1d86589e88191bc7cc0440964145b","toolName":"read","content":[{"type":"text","text":"services:\r\n  # 1. THE INFERENCE ENGINE\r\n  ollama:\r\n    image: ollama/ollama:latest\r\n    container_name: ollama\r\n    restart: unless-stopped\r\n    ports:\r\n      - \"11434:11434\"\r\n    volumes:\r\n      - \"./data/ollama:/root/.ollama\"\r\n      - \"C:/Apollo/Intel:/root/apollo_intel\"\r\n      - \"C:/Apollo/Vault:/root/apollo_vault\"\r\n    environment:\r\n      OLLAMA_FLASH_ATTENTION: \"1\"\r\n      OLLAMA_KV_CACHE_TYPE: \"q4_0\"\r\n      OLLAMA_NUM_GPU: \"-1\"\r\n    deploy:\r\n      resources:\r\n        reservations:\r\n          devices:\r\n            - driver: nvidia\r\n              count: all\r\n              capabilities: [\"gpu\"]\r\n\r\n  # 2. THE LIBRARIAN\r\n  apollo-agent:\r\n    image: ghcr.io/openclaw/openclaw:latest\r\n    container_name: apollo-agent\r\n    restart: unless-stopped\r\n    ports:\r\n      - \"18789:18789\"\r\n    environment:\r\n      OLLAMA_BASE_URL: \"http://ollama:11434\"\r\n      OPENCLAW_GATEWAY_PORT: \"18789\"\r\n      ALLOW_FILE_MODIFICATION: \"true\"\r\n      ALLOW_DESKTOP_INTERACTION: \"true\"\r\n      WORKSPACE_DIR: \"/home/node/.openclaw/workspace\"\r\n      GATEWAY_TOKEN: \"${APOLLO_TOKEN}\"\r\n    volumes:\r\n      - \"C:/Apollo/Intel:/home/node/.openclaw\"\r\n      - \"C:/Apollo:/home/node/.openclaw/workspace\"\r\n      # Compatibility aliases for old paths already used in-session\r\n      - \"C:/Apollo/Vault:/home/node/.openclaw/workspace/vault\"\r\n      - \"C:/Apollo/Vault/Raw:/home/node/.openclaw/workspace/vault/raw\"\r\n      - \"C:/Apollo/Vault/Clean:/home/node/.openclaw/workspace/vault/clean\"\r\n      - \"C:/Apollo/Vault/Database:/home/node/.openclaw/workspace/vault/database\"\r\n    depends_on:\r\n      - ollama\r\n    command: [\"node\", \"dist/index.js\", \"gateway\"]\r\n\r\n  # 3. THE PURIFIER\r\n  docling:\r\n    image: ghcr.io/docling-project/docling-serve:latest\r\n    container_name: docling\r\n    ports:\r\n      - \"5001:5001\"\r\n    volumes:\r\n      - \"C:/Apollo/Vault/Raw:/root/apollo_raw\"\r\n      - \"C:/Apollo/Vault/Clean:/root/apollo_clean\"\r\n\r\n  # 4. THE MEMORY\r\n  lightrag:\r\n    image: ghcr.io/hkuds/lightrag:latest\r\n    container_name: apollo-lightrag\r\n    ports:\r\n      - \"9621:9621\"\r\n    volumes:\r\n      - \"C:/Apollo/Vault/Database:/app/data/rag_storage\"\r\n      - \"C:/Apollo/Vault/Clean:/app/data/inputs\"\r\n    environment:\r\n      LLM_BINDING: \"ollama\"\r\n      LLM_BINDING_HOST: \"http://ollama:11434\"\r\n      LLM_MODEL: \"Apollo-Architect\"\r\n      EMBEDDING_BINDING: \"ollama\"\r\n      EMBEDDING_BINDING_HOST: \"http://ollama:11434\"\r\n      EMBEDDING_MODEL: \"nomic-embed-text\"\r\n      SUMMARY_CONTEXT_SIZE: \"32000\"\r\n    depends_on:\r\n      - ollama\r\n\r\n  # 5. THE SCOUTS\r\n  browserless:\r\n    image: browserless/chrome:latest\r\n    container_name: browserless\r\n    restart: unless-stopped\r\n    ports:\r\n      - \"3003:3000\"\r\n\r\n  crawl4ai:\r\n    image: unclecode/crawl4ai:latest\r\n    container_name: apollo-scout\r\n    restart: unless-stopped\r\n    ports:\r\n      - \"11235:11235\"\r\n    environment:\r\n      MAX_CONCURRENT_TASKS: \"3\"\r\n\r\n  # 6. THE CONDUCTORS\r\n  n8n:\r\n    image: n8nio/n8n:latest\r\n    container_name: n8n\r\n    ports:\r\n      - \"5678:5678\"\r\n    environment:\r\n      N8N_HOST: \"0.0.0.0\"\r\n      N8N_PORT: \"5678\"\r\n      N8N_RUNNERS_ENABLED: \"true\"\r\n    volumes:\r\n      - \"./data/n8n:/home/node/.n8n\"\r\n      - \"C:/Apollo/Intel:/home/node/apollo_intel\"\r\n    depends_on:\r\n      - n8n_db\r\n\r\n  n8n_db:\r\n    image: postgres:16\r\n    container_name: n8n_db\r\n    environment:\r\n      POSTGRES_USER: \"apollo_admin\"\r\n      POSTGRES_PASSWORD: \"secure_password_2026\"\r\n      POSTGRES_DB: \"apollo_state\"\r\n    volumes:\r\n      - \"./data/postgres:/var/lib/postgresql/data\"\r\n\r\n  # 7. THE INTERFACE\r\n  open-webui:\r\n    image: ghcr.io/open-webui/open-webui:cuda\r\n    container_name: open-webui\r\n    ports:\r\n      - \"3000:8080\"\r\n    environment:\r\n      OLLAMA_BASE_URL: \"http://ollama:11434\"\r\n      WEBUI_SECRET_KEY: \"apollo_v2_secret\"\r\n    volumes:\r\n      - \"./data/open-webui:/app/backend/data\"\r\n      - \"C:/Apollo/Intel:/app/backend/data/apollo_intel\"\r\n      - \"C:/Apollo:/app/backend/data/apollo_repo\"\r\n    depends_on:\r\n      - ollama"}],"isError":false,"timestamp":1776408677732}}
